RewriteRule ^document-database-new/?$ /resources [R=301,L,NE]
RewriteRule ^links-page/?$ /resources [R=301,L,NE]
RewriteRule ^links-page-2/?$ /resources [R=301,L,NE]
RewriteRule ^home/?$ / [R=301,L,NE]
RewriteRule ^posts/?$ /news [R=301,L,NE]
RewriteRule ^about/?$ /about-us [R=301,L,NE]
RewriteRule ^bulletins/?$ /resources [R=301,L,NE]
RewriteRule ^bulletins-2/?$ /resources [R=301,L,NE]
RewriteRule ^general-bulletins/?$ /resources [R=301,L,NE]
RewriteRule ^education-bulletins/?$ /resources [R=301,L,NE]
RewriteRule ^equalities-bulletins/?$ /resources [R=301,L,NE]
RewriteRule ^health-safety-bulletins/?$ /resources [R=301,L,NE]
RewriteRule ^labour-link-bulletins/?$ /resources [R=301,L,NE]
RewriteRule ^membership-bulletins/?$ /resources [R=301,L,NE]
RewriteRule ^welfare-bulletins/?$ /resources [R=301,L,NE]
RewriteRule ^retired-members-bulletins/?$ /resources [R=301,L,NE]
RewriteRule ^sector-bulletins/?$ /resources [R=301,L,NE]
RewriteRule ^branch-chair-bulletins/?$ /resources [R=301,L,NE]
RewriteRule ^branch-secretary-bulletins/?$ /resources [R=301,L,NE]
RewriteRule ^other-bulletins/?$ /resources [R=301,L,NE]

# --- Serve prerendered HTML for clean, extensionless URLs (no forced trailing slash) ---
# nuxt generate writes <route>/index.html; this serves it for /route directly,
# with DirectorySlash Off above suppressing mod_dir's automatic slash redirect.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{DOCUMENT_ROOT}/$1/index.html -f
RewriteRule ^(.+?)/?$ /$1/index.html [L]

# --- 404 ---
ErrorDocument 404 /404.html
